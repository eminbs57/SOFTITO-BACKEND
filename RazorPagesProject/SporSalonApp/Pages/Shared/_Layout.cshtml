<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Spor Salonu Yönetim</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            .sidebar {
                height: 100vh;
                background: #2C3E50;
                color: white;
                padding-top: 20px;
            }

            .sidebar a {
                color: white;
                display: block;
                padding: 15px;
                text-decoration: none;
            }

            .sidebar a:hover {
                background: #34495E;
            }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 sidebar">
                <h4 class="text-center">Yönetim Paneli</h4>
                <hr />
                <a href="/Admin/Uyeler/Index">Üyeler</a>
                <a href="/Admin/Duyurular/Index">Duyurular</a>
                <a href="/Admin/Ekipmanlar/Index">Ekipmanlar</a>
                <a href="/Admin/Raporlar/Rapor">Raporlar</a>
            </div>

            <div class="col-md-10 p-0">
                <nav class="navbar navbar-light bg-white shadow-sm mb-4 px-4">
                    <div class="container-fluid">
                        <a class="navbar-brand" href="/">Ana Sayfa</a>
                        <div class="d-flex align-items-center">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="me-3 fw-bold text-dark">@User.Identity.Name</span>
                                <form method="post" asp-page="/Auth/Logout" class="m-0">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Çıkış Yap</button>
                                </form>
                            }
                        </div>
                    </div>
                </nav>
                <div class="p-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>