@page
@model SporSalonApp.Pages.Admin.Ekipmanlar.IndexModel
@{
}

<br />
<h2>Ekipmanlar Listesi</h2>
<a class="btn btn-primary btn-sm mb-3" href="/Admin/Ekipmanlar/Create">Ekipman Ekle</a>

<form method="GET" class="mb-3">
    <div class="input-group">
        <input type="text" class="form-control" name="search" value="@Model.SearchTerm"
               placeholder="Ekipman adı veya durum ara...">
        <button type="submit" class="btn btn-primary">Ara</button>
        <a href="/Admin/Ekipmanlar/Index" class="btn btn-secondary">Temizle</a>
    </div>
</form>

<table class="table mt-3">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ad</th>
            <th>Durum</th>
            <th>Satın Alma Tarihi</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Liste)
        {
            <tr>
                <td>@item.ID</td>
                <td>@item.Ad</td>
                <td>@item.Durum</td>
                <td>@item.SatinAlmaTarihi</td>
                <td>
                    <a class="btn btn-primary btn-sm" href="/Admin/Ekipmanlar/Edit?id=@item.ID">Edit</a>
                    <a class="btn btn-danger btn-sm" href="/Admin/Ekipmanlar/Delete?id=@item.ID"
                       onclick="return confirm('Emin misiniz?');">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>