@model MvcProject.ViewModels.ReportViewModel

@{
    ViewData["Title"] = "Raporlar";
}

<style>
    /* Modern Dashboard Styling */
    .dashboard-header {
        font-weight: 700;
        letter-spacing: -0.5px;
        color: #2c3e50;
        margin-bottom: 30px;
    }

    .report-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
        color: #fff;
        position: relative;
    }

    .report-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
    }

    /* Gradients for cards */
    .card-vehicles {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .card-drivers {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        color: #1a4a38; /* Koyu yeşil yazı */
    }

    .card-depos {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        color: #5c192d;
    }

    .card-capacity {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }

    .card-users {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    }

    .card-departments {
        background: linear-gradient(135deg, #ff0844 0%, #ffb199 100%);
    }

    .report-card .card-body {
        padding: 30px 25px;
        position: relative;
        z-index: 2;
    }

    .report-card .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        opacity: 0.9;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .report-card .display-5 {
        font-weight: 700;
        font-size: 3rem;
        margin-bottom: 0;
    }

    .report-card .card-footer {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(5px);
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        padding: 15px 25px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        z-index: 2;
        position: relative;
    }

    .report-card .stretched-link {
        color: inherit;
        font-weight: 600;
        text-decoration: none;
        letter-spacing: 0.5px;
    }

    .report-card .stretched-link:hover {
        opacity: 0.8;
    }

    /* Background Watermark Icons */
    .card-icon-bg {
        position: absolute;
        right: -10px;
        bottom: -20px;
        font-size: 8rem;
        opacity: 0.15;
        z-index: 1;
        transform: rotate(-15deg);
        transition: all 0.3s ease;
    }

    .report-card:hover .card-icon-bg {
        transform: rotate(0deg) scale(1.1);
        opacity: 0.25;
    }

    /* Link color adjustment for light background cards */
    .card-drivers .stretched-link, 
    .card-depos .stretched-link {
        color: inherit;
    }
    .card-drivers .card-footer, 
    .card-depos .card-footer {
        border-top: 1px solid rgba(0, 0, 0, 0.1);
        background: rgba(255, 255, 255, 0.3);
    }
</style>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="dashboard-header"><i class="bi bi-grid-1x2-fill text-primary me-2"></i> Sistem Özeti</h1>
        <ol class="breadcrumb mb-0 bg-white px-3 py-2 rounded-pill shadow-sm">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Ana Sayfa</a></li>
            <li class="breadcrumb-item active fw-bold">Dashboard</li>
        </ol>
    </div>

    <!-- Lojistik Verileri -->
    <h4 class="text-muted mb-3 fw-bold" style="font-size: 1.2rem;">Lojistik Operasyonları</h4>
    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="card report-card card-vehicles">
                <i class="bi bi-truck card-icon-bg"></i>
                <div class="card-body">
                    <h5 class="card-title">Kayıtlı Araç</h5>
                    <h2 class="display-5">@Model.TotalVehicles</h2>
                </div>
                <div class="card-footer">
                    <a class="stretched-link" asp-controller="Vehicles" asp-action="Index">Araçları Yönet <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card report-card card-drivers">
                <i class="bi bi-person-vcard card-icon-bg"></i>
                <div class="card-body">
                    <h5 class="card-title">Aktif Sürücü</h5>
                    <h2 class="display-5">@Model.TotalDrivers</h2>
                </div>
                <div class="card-footer">
                    <a class="stretched-link" asp-controller="Drivers" asp-action="Index">Sürücüleri Yönet <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card report-card card-depos">
                <i class="bi bi-building-check card-icon-bg"></i>
                <div class="card-body">
                    <h5 class="card-title">Toplam Depo</h5>
                    <h2 class="display-5">@Model.TotalDepos</h2>
                </div>
                <div class="card-footer">
                    <a class="stretched-link" asp-controller="Depos" asp-action="Index">Depoları Yönet <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card report-card card-capacity">
                <i class="bi bi-box-seam card-icon-bg"></i>
                <div class="card-body pb-2">
                    <h5 class="card-title">Kapasite & Hacim</h5>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fs-5 opacity-75">Araçlar</span>
                            <span class="fs-5 fw-bold">@Model.TotalVehicleCapacity <small>kg</small></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="fs-5 opacity-75">Depolar</span>
                            <span class="fs-5 fw-bold">@Model.TotalDepoVolume <small>m³</small></span>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <span class="fw-bold">Genel Lojistik Hacmi</span>
                </div>
            </div>
        </div>
    </div>

    <!-- İK Verileri -->
    <h4 class="text-muted mb-3 fw-bold" style="font-size: 1.2rem;">Sistem & Kullanıcı Yönetimi</h4>
    <div class="row g-4">
        <div class="col-xl-6 col-md-6">
            <div class="card report-card card-users">
                <i class="bi bi-people-fill card-icon-bg" style="font-size: 10rem; bottom: -30px;"></i>
                <div class="card-body">
                    <h5 class="card-title">Sistem Kullanıcıları</h5>
                    <h2 class="display-5">@Model.TotalUsers</h2>
                </div>
                <div class="card-footer">
                    <a class="stretched-link" asp-controller="Users" asp-action="Index">Kullanıcıları Yönet <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>

        <div class="col-xl-6 col-md-6">
            <div class="card report-card card-departments">
                <i class="bi bi-diagram-3-fill card-icon-bg" style="font-size: 10rem; bottom: -30px;"></i>
                <div class="card-body">
                    <h5 class="card-title">Departmanlar</h5>
                    <h2 class="display-5">@Model.TotalDepartments</h2>
                </div>
                <div class="card-footer">
                    <a class="stretched-link" asp-controller="Departments" asp-action="Index">Departmanları Yönet <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}
