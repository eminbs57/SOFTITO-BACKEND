@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="text-center py-4">
    <div class="mb-6 flex justify-center">
        <div class="w-20 h-20 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600 shadow-inner">
            <i class="fa-solid fa-store text-4xl"></i>
        </div>
    </div>
    
    <h2 class="text-2xl font-bold text-gray-800 mb-4">E-Ticaret Platformuna Hoş Geldiniz!</h2>
    <p class="text-gray-600 mb-2">En trend elektronik ürünler, akıllı telefonlar, bilgisayarlar ve aksesuarları en uygun fiyatlarla burada bulabilirsiniz.</p>
    <p class="text-gray-500 text-sm mb-8">Güvenli ve kaliteli alışverişin yeni adresi.</p>
    
    @if (!User.Identity.IsAuthenticated)
    {
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-6 border-t border-gray-100 pt-8">
            <a href="/Account/Login" class="w-full sm:w-auto px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg shadow-sm transition-colors flex items-center justify-center">
                <i class="fa-solid fa-right-to-bracket mr-2"></i> Yönetici Girişi
            </a>
            <a href="/Account/Register" class="w-full sm:w-auto px-6 py-2.5 bg-white hover:bg-gray-50 text-indigo-600 border border-indigo-600 font-medium rounded-lg shadow-sm transition-colors flex items-center justify-center">
                <i class="fa-solid fa-user-plus mr-2"></i> Kayıt Ol
            </a>
        </div>
    }
    else
    {
        <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
            <a href="/Order/Index" class="block p-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
                <i class="fa-solid fa-cart-shopping text-indigo-500 text-2xl mb-3"></i>
                <h3 class="font-bold text-gray-800">Siparişleri Yönet</h3>
                <p class="text-sm text-gray-500 mt-1">Müşteri siparişlerini görüntüle ve durumu güncelle.</p>
            </a>
            <a href="/Product/Index" class="block p-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
                <i class="fa-solid fa-box text-indigo-500 text-2xl mb-3"></i>
                <h3 class="font-bold text-gray-800">Ürün Kataloğu</h3>
                <p class="text-sm text-gray-500 mt-1">Stoktaki ürünleri incele ve fiyatları yönet.</p>
            </a>
            <a href="/Report/Index" class="block p-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
                <i class="fa-solid fa-chart-pie text-indigo-500 text-2xl mb-3"></i>
                <h3 class="font-bold text-gray-800">İstatistikler</h3>
                <p class="text-sm text-gray-500 mt-1">Satış, gelir ve stok raporlarını detaylıca analiz et.</p>
            </a>
        </div>
    }
</div>
