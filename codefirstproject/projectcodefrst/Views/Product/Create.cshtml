@model projectcodefirst.Models.Product

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    var categories = ViewBag.Categories as List<projectcodefirst.Models.Category>;
}

<div class="max-w-2xl mx-auto bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mt-6">
    <!-- Header -->
    <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-xl font-semibold text-gray-800">Yeni Ürün Ekle</h2>
        <p class="text-sm text-gray-500 mt-1">Stoka yeni bir ürün eklemek için bilgileri eksiksiz doldurun.</p>
    </div>

    <!-- Form -->
    <form asp-action="Create" method="post" class="p-6">
        <div class="space-y-6">
            <!-- Ürün Adı -->
            <div>
                <label for="Name" class="block text-sm font-medium text-gray-700 mb-1">Ürün Adı</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-box text-gray-400"></i>
                    </div>
                    <input type="text" id="Name" name="Name" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" placeholder="Ürün Adı" required />
                </div>
            </div>

            <!-- Fiyat ve Stok (Yan yana) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Fiyat -->
                <div>
                    <label for="Price" class="block text-sm font-medium text-gray-700 mb-1">Fiyat (₺)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-lira-sign text-gray-400"></i>
                        </div>
                        <input type="number" step="0.01" id="Price" name="Price" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" placeholder="0.00" required />
                    </div>
                </div>

                <!-- Stok -->
                <div>
                    <label for="Stock" class="block text-sm font-medium text-gray-700 mb-1">Stok Miktarı</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-cubes text-gray-400"></i>
                        </div>
                        <input type="number" id="Stock" name="Stock" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" placeholder="0" required />
                    </div>
                </div>
            </div>

            <!-- Kategori -->
            <div>
                <label for="CategoryId" class="block text-sm font-medium text-gray-700 mb-1">Kategori</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-tags text-gray-400"></i>
                    </div>
                    <select id="CategoryId" name="CategoryId" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors appearance-none" required>
                        <option value="" disabled selected>-- Kategori Seçin --</option>
                        @if (categories != null)
                        {
                            foreach (var category in categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        }
                    </select>
                    <!-- Custom Arrow Icon for Select -->
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-chevron-down text-gray-400 text-sm"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- İşlem Butonları -->
        <div class="mt-8 pt-5 border-t border-gray-100 flex justify-end gap-4">
            <a href="/Product/Index" class="inline-flex justify-center items-center px-4 py-2 bg-white border border-gray-300 text-sm font-medium text-gray-700 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm">
                İptal
            </a>
            <button type="submit" class="inline-flex justify-center items-center px-6 py-2 bg-indigo-600 border border-transparent text-sm font-medium text-white rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm">
                <i class="fa-solid fa-check mr-2"></i> Kaydet
            </button>
        </div>
    </form>
</div>
