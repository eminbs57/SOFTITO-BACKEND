@model projectcodefirst.Models.Customer

@{
    ViewData["Title"] = "Yeni Müşteri Ekle";
}

<div class="max-w-2xl mx-auto bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mt-6">
    <!-- Header -->
    <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-xl font-semibold text-gray-800">Yeni Müşteri Ekle</h2>
        <p class="text-sm text-gray-500 mt-1">Sisteme yeni bir müşteri kaydı oluşturmak için aşağıdaki formu doldurun.</p>
    </div>

    <!-- Form -->
    <form asp-action="Create" method="post" class="p-6">
        <div class="space-y-6">
            <!-- Ad Soyad -->
            <div>
                <label for="FullName" class="block text-sm font-medium text-gray-700 mb-1">Ad Soyad</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-user text-gray-400"></i>
                    </div>
                    <input type="text" id="FullName" name="FullName" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" placeholder="Müşteri Adı Soyadı" required />
                </div>
            </div>

            <!-- Email -->
            <div>
                <label for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email Adresi</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-regular fa-envelope text-gray-400"></i>
                    </div>
                    <input type="email" id="Email" name="Email" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" placeholder="ornek@musteri.com" required />
                </div>
            </div>
        </div>

        <!-- İşlem Butonları -->
        <div class="mt-8 pt-5 border-t border-gray-100 flex justify-end gap-4">
            <a href="/Customer/Index" class="inline-flex justify-center items-center px-4 py-2 bg-white border border-gray-300 text-sm font-medium text-gray-700 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm">
                İptal
            </a>
            <button type="submit" class="inline-flex justify-center items-center px-6 py-2 bg-indigo-600 border border-transparent text-sm font-medium text-white rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm">
                <i class="fa-solid fa-check mr-2"></i> Kaydet
            </button>
        </div>
    </form>
</div>
