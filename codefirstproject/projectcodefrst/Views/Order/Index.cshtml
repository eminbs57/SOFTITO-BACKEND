@model IEnumerable<projectcodefirst.Models.Order>

@{
    ViewData["Title"] = "Siparişler";
}

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <!-- Top Action Bar -->
    <div class="p-4 border-b border-gray-200 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <!-- Search Form -->
        <form method="get" class="flex-1 w-full md:max-w-md relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <i class="fa-solid fa-magnifying-glass text-gray-400"></i>
            </div>
            <input type="text" name="searchString" placeholder="Müşteri veya Ürün Ara..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" />
            <button type="submit" class="hidden">Ara</button> <!-- Enter to search -->
        </form>

        <!-- Action Buttons -->
        <div class="flex items-center space-x-2">
            <a href="/Order/ExportToPdf" class="inline-flex items-center px-3 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 transition-colors">
                <i class="fa-solid fa-file-pdf mr-2"></i> PDF
            </a>
            <a href="/Order/ExportToExcel" class="inline-flex items-center px-3 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 transition-colors">
                <i class="fa-solid fa-file-excel mr-2"></i> Excel
            </a>
            <a href="/Order/Create" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 transition-colors ml-2">
                <i class="fa-solid fa-plus mr-2"></i> Yeni Sipariş Ekle
            </a>
        </div>
    </div>

    <!-- Table Content -->
    <div class="overflow-x-auto">
        <table id="ordersTable" class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tarih</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Müşteri</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ürün</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Miktar</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">İşlemler</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors duration-150">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.OrderDate.ToString("g")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium">@(item.Customer != null ? item.Customer.FullName : "-")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(item.Product != null ? item.Product.Name : "-")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                                    @item.Quantity Adet
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href="/Order/Edit/@item.Id" class="text-indigo-600 hover:text-indigo-900 bg-indigo-50 p-2 rounded-md hover:bg-indigo-100 transition-colors inline-block mr-1" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a href="/Order/Delete/@item.Id" onclick="return confirm('Silmek istediğinize emin misiniz?');" class="text-red-600 hover:text-red-900 bg-red-50 p-2 rounded-md hover:bg-red-100 transition-colors inline-block" title="Sil">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-500">
                            <div class="flex flex-col items-center justify-center">
                                <i class="fa-solid fa-box-open text-4xl text-gray-300 mb-3"></i>
                                <p>Henüz kayıtlı sipariş bulunmuyor.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <!-- DataTables JS & Plugins -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    
    <script>
        $(document).ready(function() {
            // Sadece tabloyu renklendirme ve sayfalama için DataTable kullanıyoruz,
            // butonları kendi arayüzümüze (Tailwind) çektik.
            $('#ordersTable').DataTable({
                dom: 'rtip', // Sadece tablo (t), bilgi (i), sayfalama (p). Butonlar ve kendi arama formumuzu dışarı aldık.
                searching: false, // Sunucu tabanlı arama yapılıyor
                paging: false,
                info: false,
                ordering: true // Sütun sıralaması aktif kalsın
            });
        });
    </script>
}
