@model ObiletApp.Core.Entities.Campaign
@{
    ViewData["Title"] = "Yeni Kampanya";
}

<div class="max-w-700">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4 border-0">
            <h3 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i> Yeni Kampanya Ekle</h3>
        </div>
        <div class="card-body p-5" style="background-color: var(--dark-surface);">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-4 p-3 bg-danger bg-opacity-25 rounded-3"></div>

                                <div class="form-floating mb-4">
                    <input asp-for="Name" class="form-control bg-dark border-secondary text-white" placeholder="Ad" />
                    <label asp-for="Name" class="text-white-50">Ad</label>
                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="DiscountCode" class="form-control bg-dark border-secondary text-white" placeholder="İndirim Kodu" />
                    <label asp-for="DiscountCode" class="text-white-50">İndirim Kodu</label>
                    <span asp-validation-for="DiscountCode" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="DiscountPercentage" class="form-control bg-dark border-secondary text-white" placeholder="İndirim Yüzdesi" />
                    <label asp-for="DiscountPercentage" class="text-white-50">İndirim Yüzdesi</label>
                    <span asp-validation-for="DiscountPercentage" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="StartDate" class="form-control bg-dark border-secondary text-white" placeholder="Başlangıç Tarihi" />
                    <label asp-for="StartDate" class="text-white-50">Başlangıç Tarihi</label>
                    <span asp-validation-for="StartDate" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="EndDate" class="form-control bg-dark border-secondary text-white" placeholder="Bitiş Tarihi" />
                    <label asp-for="EndDate" class="text-white-50">Bitiş Tarihi</label>
                    <span asp-validation-for="EndDate" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="CompanyId" class="form-control bg-dark border-secondary text-white" placeholder="Firma" />
                    <label asp-for="CompanyId" class="text-white-50">Firma</label>
                    <span asp-validation-for="CompanyId" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex gap-3 mt-5 pt-3 border-top border-secondary">
                    <a asp-action="Index" class="btn btn-light btn-lg flex-fill rounded-pill fw-bold bg-secondary bg-opacity-25 border-0 text-white">İptal</a>
                    <button type="submit" class="btn btn-primary btn-lg flex-fill rounded-pill fw-bold shadow">
                        <i class="bi bi-check2 me-1"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
