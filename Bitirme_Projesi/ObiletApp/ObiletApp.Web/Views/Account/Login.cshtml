@model ObiletApp.Web.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-dark text-light p-4 rounded-4 shadow-lg border-secondary">
                <h3 class="text-center mb-4"><i class="fa-solid fa-user me-2"></i>Giriş Yap</h3>
                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">E-Posta</label>
                        <input asp-for="Email" class="form-control bg-secondary text-white border-0" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Şifre</label>
                        <input asp-for="Password" type="password" class="form-control bg-secondary text-white border-0" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">Giriş Yap</button>

                    <div class="text-center mt-3">
                        <span class="text-muted">Hesabınız yok mu?</span>
                        <a href="/Account/Register" class="text-decoration-none text-info">Kayıt Ol</a>
                    </div>

                    <div class="text-center mt-4 pt-3 border-top border-secondary">
                        <a href="/Account/AdminRegister" class="text-decoration-none text-warning small opacity-75">
                            <i class="fa-solid fa-user-shield me-1"></i>Sistem Yöneticisi Olarak Kayıt Ol
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
