@model ObiletApp.Core.Entities.Payment
@{
    ViewData["Title"] = "Ödeme Düzenle";
}

<div class="max-w-700">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-warning text-dark p-4 border-0">
            <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Ödeme Düzenle</h3>
        </div>
        <div class="card-body p-5" style="background-color: var(--dark-surface);">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedDate" />

                <div asp-validation-summary="All" class="text-danger mb-4 p-3 bg-danger bg-opacity-25 rounded-3"></div>

                                <div class="form-floating mb-4">
                    <input asp-for="TicketId" class="form-control bg-dark border-secondary text-white" placeholder="Bilet" />
                    <label asp-for="TicketId" class="text-white-50">Bilet</label>
                    <span asp-validation-for="TicketId" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="Amount" class="form-control bg-dark border-secondary text-white" placeholder="Tutar" />
                    <label asp-for="Amount" class="text-white-50">Tutar</label>
                    <span asp-validation-for="Amount" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="Method" class="form-control bg-dark border-secondary text-white" placeholder="Ödeme Yöntemi" />
                    <label asp-for="Method" class="text-white-50">Ödeme Yöntemi</label>
                    <span asp-validation-for="Method" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="IsSuccessful" class="form-control bg-dark border-secondary text-white" placeholder="Durum" />
                    <label asp-for="IsSuccessful" class="text-white-50">Durum</label>
                    <span asp-validation-for="IsSuccessful" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex gap-3 mt-5 pt-3 border-top border-secondary">
                    <a asp-action="Index" class="btn btn-light btn-lg flex-fill rounded-pill fw-bold bg-secondary bg-opacity-25 border-0 text-white">İptal</a>
                    <button type="submit" class="btn btn-warning btn-lg flex-fill rounded-pill fw-bold shadow">
                        <i class="bi bi-save me-1"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
