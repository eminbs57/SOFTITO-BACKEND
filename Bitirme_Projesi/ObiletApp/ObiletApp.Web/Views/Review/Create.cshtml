@model ObiletApp.Core.Entities.Review
@{
    ViewData["Title"] = "Yeni Değerlendirme";
}

<div class="max-w-700">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4 border-0">
            <h3 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i> Yeni Değerlendirme Ekle</h3>
        </div>
        <div class="card-body p-5" style="background-color: var(--dark-surface);">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-4 p-3 bg-danger bg-opacity-25 rounded-3"></div>

                                <div class="form-floating mb-4">
                    <input asp-for="TripId" class="form-control bg-dark border-secondary text-white" placeholder="Sefer" />
                    <label asp-for="TripId" class="text-white-50">Sefer</label>
                    <span asp-validation-for="TripId" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="UserId" class="form-control bg-dark border-secondary text-white" placeholder="Kullanıcı" />
                    <label asp-for="UserId" class="text-white-50">Kullanıcı</label>
                    <span asp-validation-for="UserId" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="Rating" class="form-control bg-dark border-secondary text-white" placeholder="Puan" />
                    <label asp-for="Rating" class="text-white-50">Puan</label>
                    <span asp-validation-for="Rating" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="Comment" class="form-control bg-dark border-secondary text-white" placeholder="Yorum" />
                    <label asp-for="Comment" class="text-white-50">Yorum</label>
                    <span asp-validation-for="Comment" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex gap-3 mt-5 pt-3 border-top border-secondary">
                    <a asp-action="Index" class="btn btn-light btn-lg flex-fill rounded-pill fw-bold bg-secondary bg-opacity-25 border-0 text-white">İptal</a>
                    <button type="submit" class="btn btn-primary btn-lg flex-fill rounded-pill fw-bold shadow">
                        <i class="bi bi-check2 me-1"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
