@model ObiletApp.Core.Entities.Trip
@{
    ViewData["Title"] = "Yeni Sefer";
}

<div class="max-w-700">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4 border-0">
            <h3 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i> Yeni Sefer Ekle</h3>
        </div>
        <div class="card-body p-5" style="background-color: var(--dark-surface);">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-4 p-3 bg-danger bg-opacity-25 rounded-3"></div>

                                <div class="form-floating mb-4">
                    <input asp-for="RouteId" class="form-control bg-dark border-secondary text-white" placeholder="Güzergah" />
                    <label asp-for="RouteId" class="text-white-50">Güzergah</label>
                    <span asp-validation-for="RouteId" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="VehicleId" class="form-control bg-dark border-secondary text-white" placeholder="Araç" />
                    <label asp-for="VehicleId" class="text-white-50">Araç</label>
                    <span asp-validation-for="VehicleId" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="DepartureTime" class="form-control bg-dark border-secondary text-white" placeholder="Kalkış Zamanı" />
                    <label asp-for="DepartureTime" class="text-white-50">Kalkış Zamanı</label>
                    <span asp-validation-for="DepartureTime" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="ArrivalTime" class="form-control bg-dark border-secondary text-white" placeholder="Varış Zamanı" />
                    <label asp-for="ArrivalTime" class="text-white-50">Varış Zamanı</label>
                    <span asp-validation-for="ArrivalTime" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="Price" class="form-control bg-dark border-secondary text-white" placeholder="Fiyat" />
                    <label asp-for="Price" class="text-white-50">Fiyat</label>
                    <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex gap-3 mt-5 pt-3 border-top border-secondary">
                    <a asp-action="Index" class="btn btn-light btn-lg flex-fill rounded-pill fw-bold bg-secondary bg-opacity-25 border-0 text-white">İptal</a>
                    <button type="submit" class="btn btn-primary btn-lg flex-fill rounded-pill fw-bold shadow">
                        <i class="bi bi-check2 me-1"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
