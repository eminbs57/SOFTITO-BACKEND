@{
    ViewData["Title"] = "Biletiniz Hazır";
}

<div class="container mt-5 pt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 rounded-4 shadow" style="background: var(--dark-surface); overflow: hidden;">

                <div class="bg-success text-white text-center p-4">
                    <div class="rounded-circle bg-white text-success d-inline-flex justify-content-center align-items-center mb-3" style="width: 70px; height: 70px;">
                        <i class="fa-solid fa-check fs-1"></i>
                    </div>
                    <h3 class="mb-0">Ödeme Başarılı!</h3>
                    <p class="mb-0 opacity-75">Biletiniz oluşturuldu ve kullanıma hazır.</p>
                </div>

                <div class="p-4 p-md-5 bg-white text-dark position-relative">

                    <div style="position: absolute; top: 0; left: 0; right: 0; height: 10px; background-image: radial-gradient(circle at 10px 0, transparent 12px, var(--dark-surface) 13px); background-size: 20px 10px; background-repeat: repeat-x;"></div>

                    <div class="text-center mb-4 mt-2">
                        <h6 class="text-muted text-uppercase fw-bold letter-spacing-1">PNR Kodu</h6>
                        <h1 class="display-5 fw-bold font-monospace text-primary">@ViewBag.PNR</h1>
                    </div>

                    <hr class="border-secondary opacity-25 my-4">

                    <div class="row text-center mb-4">
                        <div class="col-6 border-end border-secondary border-opacity-25">
                            <small class="text-muted d-block text-uppercase">Yolcu</small>
                            <h5 class="fw-bold mb-0">@ViewBag.PassengerName</h5>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block text-uppercase">Koltuk No</small>
                            <h5 class="fw-bold mb-0">@ViewBag.SeatNumber</h5>
                        </div>
                    </div>

                    <div class="d-flex flex-column align-items-center mt-5">
                        <div class="p-3 border rounded-3 bg-white shadow-sm mb-3">
                            @if (ViewBag.QrCodeImage != null)
                            {
                                <img src="data:image/png;base64,@ViewBag.QrCodeImage" alt="QR Code" width="180" height="180" />
                            }
                        </div>
                        <p class="text-muted small text-center mb-0">
                            <i class="fa-solid fa-qrcode me-1"></i> Araca binerken bu QR kodu görevliye okutunuz.
                        </p>
                    </div>
                </div>

                <div class="p-3 text-center" style="background: var(--dark-bg);">
                    <a href="/" class="btn btn-outline-light rounded-pill px-4">Ana Sayfaya Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>
