@{
    ViewData["Title"] = "Arama Sonuçları";
    var trips = ViewBag.Trips as List<dynamic>;

    var companies = new List<string>();
    var vehicleTypes = new List<string>();

    if (trips != null)
    {
        foreach (var t in trips)
        {
            var companyName = t.GetProperty("companyName").GetString();
            if (!string.IsNullOrEmpty(companyName) && !companies.Contains(companyName)) { companies.Add(companyName); }

            var vType = t.GetProperty("vehicleType").GetString();
            if (!string.IsNullOrEmpty(vType) && !vehicleTypes.Contains(vType)) { vehicleTypes.Add(vType); }
        }
    }
}

<div class="container mt-5 pt-5 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Sefer Sonuçları (@ViewBag.Date)</h2>
        @if (trips != null && trips.Count > 0)
        {
            <div class="d-flex align-items-center">
                <label class="me-2 text-muted fw-bold"><i class="bi bi-sort-down"></i> Sırala:</label>
                <select id="sortSelect" class="form-select border-0 shadow-sm" style="background: var(--dark-surface); color: white; width: 200px;">
                    <option value="time-asc">Kalkış Saati (Erken)</option>
                    <option value="time-desc">Kalkış Saati (Geç)</option>
                    <option value="price-asc">Fiyat (En Düşük)</option>
                    <option value="price-desc">Fiyat (En Yüksek)</option>
                </select>
            </div>
        }
    </div>

    @if (trips != null && trips.Count > 0)
    {
        <div class="row g-4">

            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4" style="background: var(--dark-surface);">
                    <h5 class="mb-4 text-white"><i class="bi bi-funnel-fill me-2 text-primary"></i>Filtreler</h5>

                    <div class="mb-4">
                        <h6 class="text-white-50 fw-bold mb-3">Kalkış Zamanı</h6>
                        <div class="form-check mb-2">
                            <input class="form-check-input filter-time" type="checkbox" value="gece" id="timeGece">
                            <label class="form-check-label text-light" for="timeGece">Gece (00:00 - 06:00)</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input filter-time" type="checkbox" value="sabah" id="timeSabah">
                            <label class="form-check-label text-light" for="timeSabah">Sabah (06:00 - 12:00)</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input filter-time" type="checkbox" value="ogle" id="timeOgle">
                            <label class="form-check-label text-light" for="timeOgle">Öğle (12:00 - 18:00)</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input filter-time" type="checkbox" value="aksam" id="timeAksam">
                            <label class="form-check-label text-light" for="timeAksam">Akşam (18:00 - 00:00)</label>
                        </div>
                    </div>

                    <hr class="border-secondary opacity-25">

                    <div class="mb-4">
                        <h6 class="text-white-50 fw-bold mb-3">Otobüs Firması</h6>
                        @foreach (var company in companies)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input filter-company" type="checkbox" value="@company" id="comp_@company.Replace(" ", "")">
                                <label class="form-check-label text-light" for="comp_@company.Replace(" ", "")">@company</label>
                            </div>
                        }
                    </div>

                    <hr class="border-secondary opacity-25">

                    <div class="mb-3">
                        <h6 class="text-white-50 fw-bold mb-3">Otobüs Tipi</h6>
                        @foreach (var vType in vehicleTypes)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input filter-type" type="checkbox" value="@vType" id="type_@vType.Replace(" ", "")">
                                <label class="form-check-label text-light" for="type_@vType.Replace(" ", "")">@vType</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-9" id="tripResultsContainer">
                @foreach (var trip in trips)
                {
                    var tripId = trip.GetProperty("tripId").GetInt32();
                    var companyName = trip.GetProperty("companyName").GetString();
                    var origin = trip.GetProperty("origin").GetString();
                    var destination = trip.GetProperty("destination").GetString();
                    var price = trip.GetProperty("price").GetDecimal();
                    var vehicleType = trip.GetProperty("vehicleType").GetString();
                    var depTime = trip.GetProperty("departureTime").GetDateTime().ToString("HH:mm");
                    var arrTime = trip.GetProperty("arrivalTime").GetDateTime().ToString("HH:mm");
                    var availableSeats = trip.GetProperty("availableSeats").GetInt32();

                    <div class="card p-4 rounded-4 border-0 shadow-sm mb-3 trip-card" 
                         style="background: var(--dark-surface); transition: all 0.3s ease;"
                         data-company="@companyName" 
                         data-type="@vehicleType" 
                         data-price="@price.ToString(System.Globalization.CultureInfo.InvariantCulture)" 
                         data-time="@depTime">

                        <div class="row align-items-center">
                            <div class="col-md-2 text-center">
                                <i class="fa-solid fa-bus text-primary fs-1 mb-2"></i>
                                <h5 class="mb-0">@companyName</h5>
                            </div>
                            <div class="col-md-6 text-center">
                                <div class="d-flex justify-content-center align-items-center">
                                    <div class="text-end me-4">
                                        <h4 class="mb-0">@depTime</h4>
                                        <small class="text-muted">@origin</small>
                                    </div>
                                    <div class="px-3" style="border-bottom: 2px dashed var(--border-color); width: 100px;">
                                        <span class="badge bg-secondary mb-1">@vehicleType</span>
                                    </div>
                                    <div class="text-start ms-4">
                                        <h4 class="mb-0">@arrTime</h4>
                                        <small class="text-muted">@destination</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2 text-center">
                                <h4 class="text-success mb-1 price-display">@price.ToString("N2") ₺</h4>
                                <small class="text-muted">@availableSeats Boş Koltuk</small>
                            </div>
                            <div class="col-md-2 text-end">
                                <a href="/Booking/SeatSelection?tripId=@tripId&date=@ViewBag.Date" class="btn btn-primary px-4 py-2 rounded-pill">
                                    Koltuk Seç <i class="fa-solid fa-chevron-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }

                <div id="noResultsMsg" class="alert alert-warning text-center rounded-4 p-4 d-none" style="background: rgba(255,193,7,0.1); border: 1px solid rgba(255,193,7,0.2); color: #ffc107;">
                    <i class="fa-solid fa-filter-circle-xmark fs-2 mb-3"></i>
                    <h5>Seçtiğiniz filtrelere uygun sefer bulunamadı.</h5>
                    <p class="mb-0">Lütfen filtreleri esneterek tekrar deneyin.</p>
                </div>

            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center rounded-4 p-5" style="background: rgba(255,193,7,0.1); border: 1px solid rgba(255,193,7,0.2); color: #ffc107;">
            <i class="fa-solid fa-triangle-exclamation fs-1 mb-3"></i>
            <h4>Uygun Sefer Bulunamadı</h4>
            <p>Seçtiğiniz güzergah ve tarihte henüz bir sefer planlanmamıştır.</p>
            <a href="/" class="btn btn-outline-warning mt-3">Geri Dön ve Tekrar Ara</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tripCards = Array.from(document.querySelectorAll('.trip-card'));
            const container = document.getElementById('tripResultsContainer');
            const noResultsMsg = document.getElementById('noResultsMsg');

            const timeFilters = document.querySelectorAll('.filter-time');
            const companyFilters = document.querySelectorAll('.filter-company');
            const typeFilters = document.querySelectorAll('.filter-type');
            const sortSelect = document.getElementById('sortSelect');

            const allFilters = [...timeFilters, ...companyFilters, ...typeFilters];
            allFilters.forEach(cb => cb.addEventListener('change', applyFilters));
            if(sortSelect) sortSelect.addEventListener('change', applyFilters);

            function getTimePeriod(timeStr) {
                const hour = parseInt(timeStr.split(':')[0]);
                if (hour >= 0 && hour < 6) return 'gece';
                if (hour >= 6 && hour < 12) return 'sabah';
                if (hour >= 12 && hour < 18) return 'ogle';
                return 'aksam';
            }

            function applyFilters() {

                const selectedTimes = Array.from(timeFilters).filter(cb => cb.checked).map(cb => cb.value);
                const selectedCompanies = Array.from(companyFilters).filter(cb => cb.checked).map(cb => cb.value);
                const selectedTypes = Array.from(typeFilters).filter(cb => cb.checked).map(cb => cb.value);

                let visibleCount = 0;

                tripCards.forEach(card => {
                    const comp = card.getAttribute('data-company');
                    const vType = card.getAttribute('data-type');
                    const tPeriod = getTimePeriod(card.getAttribute('data-time'));

                    let matchCompany = selectedCompanies.length === 0 || selectedCompanies.includes(comp);
                    let matchType = selectedTypes.length === 0 || selectedTypes.includes(vType);
                    let matchTime = selectedTimes.length === 0 || selectedTimes.includes(tPeriod);

                    if (matchCompany && matchType && matchTime) {
                        card.classList.remove('d-none');
                        visibleCount++;
                    } else {
                        card.classList.add('d-none');
                    }
                });

                if (visibleCount === 0 && tripCards.length > 0) {
                    noResultsMsg.classList.remove('d-none');
                } else {
                    noResultsMsg.classList.add('d-none');
                }

                applySorting();
            }

            function applySorting() {
                if(!sortSelect) return;

                const sortBy = sortSelect.value;
                const visibleCards = tripCards.filter(card => !card.classList.contains('d-none'));

                visibleCards.sort((a, b) => {
                    if (sortBy === 'price-asc' || sortBy === 'price-desc') {
                        let pA = parseFloat(a.getAttribute('data-price'));
                        let pB = parseFloat(b.getAttribute('data-price'));
                        return sortBy === 'price-asc' ? pA - pB : pB - pA;
                    } 
                    else if (sortBy === 'time-asc' || sortBy === 'time-desc') {
                        let tA = a.getAttribute('data-time');
                        let tB = b.getAttribute('data-time');
                        if (sortBy === 'time-asc') return tA.localeCompare(tB);
                        return tB.localeCompare(tA);
                    }
                    return 0;
                });

                visibleCards.forEach(card => {
                    container.insertBefore(card, noResultsMsg); 
                });
            }

            if(sortSelect && tripCards.length > 0) {
                applySorting();
            }
        });
    </script>
}
