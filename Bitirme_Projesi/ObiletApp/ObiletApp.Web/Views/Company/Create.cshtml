@model ObiletApp.Core.Entities.Company

@{
    ViewData["Title"] = "Yeni Firma Ekle";
}

<div class="container-fluid py-4 max-w-700">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4 border-0">
            <h3 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i> Yeni Firma Ekle</h3>
            <p class="mb-0 text-white-50 small mt-1">Sisteme yeni bir firma kaydedin</p>
        </div>
        <div class="card-body p-5" style="background-color: var(--dark-surface);">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-4 p-3 bg-danger bg-opacity-25 rounded-3"></div>

                <div class="form-floating mb-4">
                    <input asp-for="Name" class="form-control form-control-lg border-secondary shadow-sm" placeholder="Firma Adı" required />
                    <label asp-for="Name" class="text-muted"><i class="bi bi-building me-1"></i> Firma Adı</label>
                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="ContactInfo" class="form-control form-control-lg border-secondary shadow-sm" placeholder="İletişim Bilgisi" />
                    <label asp-for="ContactInfo" class="text-muted"><i class="bi bi-telephone me-1"></i> İletişim Bilgisi</label>
                    <span asp-validation-for="ContactInfo" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="LogoUrl" class="form-control form-control-lg border-secondary shadow-sm" placeholder="Logo URL (Örn: https://...)" />
                    <label asp-for="LogoUrl" class="text-muted"><i class="bi bi-link-45deg me-1"></i> Logo Linki (İsteğe bağlı)</label>
                    <span asp-validation-for="LogoUrl" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-floating mb-4">
                    <select asp-for="Type" class="form-select form-select-lg border-secondary shadow-sm">
                        <option value="1">Otobüs</option>
                        <option value="2">Uçak</option>
                    </select>
                    <label asp-for="Type" class="text-muted"><i class="bi bi-tags me-1"></i> Firma Tipi</label>
                    <span asp-validation-for="Type" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-flex gap-3 mt-5">
                    <a asp-action="Index" class="btn btn-light btn-lg flex-fill rounded-pill text-secondary fw-semibold shadow-sm">
                        <i class="bi bi-arrow-left me-1"></i> İptal
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg flex-fill rounded-pill fw-bold shadow">
                        <i class="bi bi-check2 me-1"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
