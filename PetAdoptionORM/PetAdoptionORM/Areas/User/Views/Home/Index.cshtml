@model IEnumerable<PetAdoptionORM.Model.Pet>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="row align-items-center mt-5 mb-5">
    <div class="col-lg-6 text-center text-lg-start mb-5 mb-lg-0">
        <h1 class="display-4 fw-bold" style="color: #1e3c72; line-height: 1.2;">
            Sıcak Bir Yuva, <br />
            <span style="color: #00c6ff;">Sevgi Dolu Bir Dost</span>
        </h1>
        <p class="lead text-muted mt-4 mb-5" style="font-size: 1.1rem; max-width: 500px; margin: 0 auto; margin-lg: 0;">
            Evcil hayvan sahiplendirme platformumuza hoş geldiniz. Barınaklardaki ve sokaklardaki sevimli dostlarımız onlara kucak açacak sıcak yuvalarını arıyor.
        </p>
        
        <div class="d-flex justify-content-center justify-content-lg-start gap-3">
            <a href="#gallery" class="btn btn-lg shadow" style="background-color: #1e3c72; color: white; border-radius: 30px; padding: 12px 30px; transition: transform 0.2s;">
                <i class="bi bi-search me-2"></i> Dostlarımızı İncele
            </a>
            <button class="btn btn-lg bg-white shadow-sm" style="color: #1e3c72; border: 1px solid #e0e0e0; border-radius: 30px; padding: 12px 30px; transition: transform 0.2s;">
                <i class="bi bi-info-circle me-2"></i> Nasıl Sahiplenirim?
            </button>
        </div>
    </div>
    
    <div class="col-lg-6 position-relative text-center">
        <!-- Decoration circle behind -->
        <div class="position-absolute rounded-circle" style="width: 400px; height: 400px; background: linear-gradient(135deg, rgba(0,198,255,0.1) 0%, rgba(30,60,114,0.1) 100%); top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: -1;"></div>
        
        <img src="https://images.unsplash.com/photo-1543852786-1cf6624b9987?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Pet Adoption Hero" class="img-fluid rounded-4 shadow-lg" style="max-height: 400px; object-fit: cover;" />
    </div>
</div>

<div id="gallery" class="mt-5 pt-5 border-top">
    <div class="text-center mb-5">
        <h2 class="fw-bold" style="color: #1e3c72;">Sahiplenmeyi Bekleyen Dostlarımız</h2>
        <p class="text-muted">Onlara sıcak bir yuva vererek hayatlarını değiştirebilirsiniz.</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var pet in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 shadow-sm pet-card" style="border-radius: 15px; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s;">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(pet.Photo))
                            {
                                <img src="@pet.Photo" class="card-img-top" alt="@pet.Name" style="height: 250px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/400x300?text=Fotograf+Yok'" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                                    <i class="bi bi-camera text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <span class="badge bg-primary position-absolute top-0 end-0 m-3 fs-6 rounded-pill">@pet.Breed.Species.SpeciesName</span>
                        </div>
                        <div class="card-body p-4">
                            <h4 class="card-title fw-bold" style="color: #1e3c72;">@pet.Name</h4>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted"><i class="bi bi-tag-fill text-info me-1"></i> @pet.Breed.BreedName</span>
                                @if (pet.HealthStatus == "Sağlıklı" || pet.HealthStatus == "İyi")
                                {
                                    <span class="badge bg-success text-white"><i class="bi bi-heart-fill me-1"></i> @pet.HealthStatus</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-heart-half me-1"></i> @pet.HealthStatus</span>
                                }
                            </div>
                            <button class="btn btn-turquoise w-100 mt-2 rounded-pill fw-bold" style="padding: 10px;">
                                <i class="bi bi-suit-heart-fill me-1"></i> Hemen Sahiplen
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-emoji-frown text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3 text-muted">Şu an sistemde sahiplendirilmeyi bekleyen bir dostumuz bulunmuyor.</h4>
            </div>
        }
    </div>
</div>

<style>
    .btn:hover {
        transform: translateY(-2px);
    }
    .pet-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .btn-turquoise {
        background-color: #00c6ff;
        color: white;
        border: none;
    }
    .btn-turquoise:hover {
        background-color: #0099cc;
        color: white;
    }
</style>
