<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pet Adoption</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --primary-blue: #1e3c72;
            --secondary-blue: #2a5298;
            --accent-turquoise: #00c6ff;
            --bg-color: #f8f9fa;
        }
        body {
            background-color: var(--bg-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .user-navbar {
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .user-navbar .navbar-brand {
            color: white !important;
            font-size: 1.5rem;
        }
        .user-navbar .nav-link {
            color: rgba(255,255,255,0.85) !important;
            transition: all 0.2s;
        }
        .user-navbar .nav-link:hover {
            color: var(--accent-turquoise) !important;
            transform: translateY(-2px);
        }
        .btn-custom-outline {
            color: white;
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 20px;
            padding: 0.375rem 1rem;
            transition: all 0.3s;
        }
        .btn-custom-outline:hover {
            background-color: rgba(255,255,255,0.1);
            border-color: white;
            color: white;
        }
        .btn-turquoise {
            background-color: var(--accent-turquoise);
            color: #fff;
            border-radius: 20px;
            padding: 0.375rem 1.2rem;
            font-weight: 600;
            border: none;
            transition: all 0.3s;
        }
        .btn-turquoise:hover {
            background-color: #0099cc;
            color: white;
            transform: scale(1.05);
        }
        .footer {
            margin-top: auto;
            background-color: white;
            border-top: 1px solid #e0e0e0;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg user-navbar mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/User/Home/Index">
                    <i class="bi bi-suit-heart-fill" style="color: var(--accent-turquoise)"></i> Pet Adoption
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#userNavbar" aria-controls="userNavbar" aria-expanded="false" aria-label="Menüyü Aç">
                    <i class="bi bi-list text-white fs-1"></i>
                </button>
                <div class="collapse navbar-collapse" id="userNavbar">
                    <ul class="navbar-nav me-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item ms-lg-4">
                                <a class="nav-link fw-semibold" href="/User/Home/Index">Ana Sayfa</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-3 d-none d-lg-block">
                                <span class="text-white-50">Hoşgeldin, <span class="text-white fw-bold">@User.Identity.Name</span></span>
                            </li>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item me-2">
                                    <a class="btn btn-turquoise" href="/Admin/Home/Index">
                                        <i class="bi bi-speedometer2"></i> Panele Dön
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="btn btn-custom-outline" href="/User/Account/Logout">
                                    <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link fw-semibold" href="/User/Account/Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-turquoise" href="/User/Account/Register">Kayıt Ol</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="flex-grow-1">
        <div class="container pb-5">
            @RenderBody()
        </div>
    </main>

    <footer class="footer py-4" style="background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%); border-top: none;">
        <div class="container text-center text-white-50">
            <p class="mb-0 text-white">&copy; 2026 - Pet Adoption System - Tüm Hakları Saklıdır.</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
