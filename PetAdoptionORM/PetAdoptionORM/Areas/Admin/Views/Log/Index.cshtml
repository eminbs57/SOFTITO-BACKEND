@model IEnumerable<string>
@{
    ViewData["Title"] = "Sistem Logları";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold" style="color: #1e3c72;">
                <i class="bi bi-terminal me-2"></i> Sistem Logları
            </h2>
            <p class="text-muted">Sistemde gerçekleşen son 100 aktivite (kayıt, giriş, hata vb.) aşağıda listelenmektedir.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-5">
        <div class="card-header text-white" style="background-color: #2b2b2b;">
            <h5 class="mb-0"><i class="bi bi-list-columns-reverse me-2"></i> Log Geçmişi</h5>
        </div>
        <div class="card-body bg-dark text-light p-4" style="font-family: monospace; border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem; max-height: 600px; overflow-y: auto;">
            @if (Model != null && Model.Any())
            {
                foreach (var log in Model)
                {
                    <div class="mb-2" style="border-bottom: 1px solid #444; padding-bottom: 5px;">
                        <span style="color: #00ff00;">>_</span> @log
                    </div>
                }
            }
            else
            {
                <div class="text-muted text-center py-4">
                    <i class="bi bi-info-circle display-4 d-block mb-3"></i>
                    Henüz sistem logu bulunmuyor veya okunamadı.
                </div>
            }
        </div>
    </div>
</div>
