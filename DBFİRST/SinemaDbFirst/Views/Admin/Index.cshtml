@model List<dbfirstProjem.Models.Filmler>

@{
    ViewData["Title"] = "Filmler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-light"><i class="fas fa-film me-2 text-danger"></i>Filmler</h3>
    <div class="d-flex align-items-center">
        <form asp-action="Index" method="get" class="d-flex me-3">
            <input type="text" name="searchString" class="form-control bg-dark text-white border-secondary me-2" placeholder="Film ara..." value="@Context.Request.Query["searchString"]" />
            <button type="submit" class="btn btn-outline-light"><i class="fas fa-search"></i></button>
        </form>
        <a asp-action="ExportToPdf_Filmler" class="btn btn-outline-danger me-2">
            <i class="fas fa-file-pdf"></i> PDF İndir
        </a>
        <a asp-action="ExportToExcel_Filmler" class="btn btn-outline-success me-2">
            <i class="fas fa-file-excel"></i> Excel İndir
        </a>
        <a asp-action="FilmEkle" class="btn btn-danger"><i class="fas fa-plus me-2"></i>Yeni Ekle</a>
    </div>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body p-0">
        <table class="table table-dark table-hover table-striped mb-0">
            <thead>
                <tr>
                    <th>Afiş</th>
                    <th>Film Adı</th>
                    <th>Türü</th>
                    <th>Süresi</th>
                    <th>Fiyatı</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-secondary py-4">Kayıtlı film bulunmamaktadır.</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="align-middle">
                            <td>
                                @if (!string.IsNullOrEmpty(item.ResimUrl))
                                {
                                    <img src="@item.ResimUrl" alt="@item.Ad" class="img-thumbnail bg-dark border-secondary" style="width: 50px; height: 75px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-secondary text-center d-flex align-items-center justify-content-center" style="width: 50px; height: 75px;">
                                        <i class="fas fa-film text-dark"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold">@item.Ad</td>
                            <td>@item.Tur</td>
                            <td>@item.SureDk Dk</td>
                            <td>@(item.Fiyat.HasValue ? item.Fiyat.Value.ToString("C") : "₺150,00")</td>
                            <td class="text-end">
                                <a asp-action="FilmDuzenle" asp-route-id="@item.FilmId" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="fas fa-edit"></i> Düzenle
                                </a>
                                <a asp-action="FilmSil" asp-route-id="@item.FilmId" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu filmi silmek istediğinize emin misiniz? Bütün seansları da etkilenebilir.');">
                                    <i class="fas fa-trash"></i> Sil
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
