@model List<dbfirstProjem.Models.Salonlar>

@{
    ViewData["Title"] = "Salonlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-light"><i class="fas fa-door-open me-2 text-danger"></i>Salonlar</h3>
    <div class="d-flex align-items-center">
        <form asp-action="Salonlar" method="get" class="d-flex me-3">
            <input type="text" name="searchString" class="form-control bg-dark text-white border-secondary me-2" placeholder="Salon ara..." value="@Context.Request.Query["searchString"]" />
            <button type="submit" class="btn btn-outline-light"><i class="fas fa-search"></i></button>
        </form>
        <a asp-action="ExportToPdf_Salonlar" class="btn btn-outline-danger me-2">
            <i class="fas fa-file-pdf"></i> PDF İndir
        </a>
        <a asp-action="ExportToExcel_Salonlar" class="btn btn-outline-success me-2">
            <i class="fas fa-file-excel"></i> Excel İndir
        </a>
        <a asp-action="SalonEkle" class="btn btn-danger"><i class="fas fa-plus me-2"></i>Yeni Ekle</a>
    </div>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body p-0">
        <table class="table table-dark table-hover table-striped mb-0">
            <thead>
                <tr>
                    <th>Salon Adı</th>
                    <th>Kapasite</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="3" class="text-center text-secondary py-4">Kayıtlı salon bulunmamaktadır.</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="align-middle">
                            <td>@item.Ad</td>
                            <td>@item.Kapasite Kişi</td>
                            <td class="text-end">
                                <a asp-action="SalonDuzenle" asp-route-id="@item.SalonId" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="fas fa-edit"></i> Düzenle
                                </a>
                                <a asp-action="SalonSil" asp-route-id="@item.SalonId" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu salonu silmek istediğinize emin misiniz?');">
                                    <i class="fas fa-trash"></i> Sil
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
