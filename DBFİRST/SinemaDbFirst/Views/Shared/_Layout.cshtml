<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>SinemaRez</title>
    <!-- Profesyonel sitenin CSS kütüphaneleri -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.13.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Kendi eklediğimiz modern CSS -->
    <style>
        body { background: #121212; color: #fff; }
        .card { transition: 0.3s; }
        .card:hover { transform: scale(1.03); }
        .navbar { background: #000; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand text-danger fw-bold" asp-controller="Home" asp-action="Index">CINEWAM</a>
            
            <div class="d-flex align-items-center">
                @if (User.Identity.IsAuthenticated)
                {
                    @if (User.IsInRole("User"))
                    {
                        <a asp-controller="Bilet" asp-action="Biletlerim" class="btn btn-outline-danger btn-sm me-3"><i class="fas fa-ticket-alt me-1"></i>Biletlerim</a>
                    }
                    <span class="navbar-text me-3 text-light">Hoşgeldin, @User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Çıkış Yap</button>
                    </form>
                }
            </div>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
</body>
</html>