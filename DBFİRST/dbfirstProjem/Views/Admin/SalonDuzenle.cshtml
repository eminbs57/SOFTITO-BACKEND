@model dbfirstProjem.Models.Salonlar

@{
    ViewData["Title"] = "Salon Düzenle";
}

<div class="card bg-dark text-white border-secondary mb-4 shadow-sm">
    <div class="card-header border-secondary d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-warning"><i class="fas fa-edit me-2"></i>Salon Düzenle</h5>
        <a asp-action="Salonlar" class="btn btn-sm btn-outline-secondary">Listeye Dön</a>
    </div>
    <div class="card-body">
        <div class="alert alert-warning bg-dark border-warning text-warning">
            <i class="fas fa-exclamation-triangle me-2"></i> Kapasiteyi değiştirmek mevcut koltuk sayısını otomatik <b>güncellemez</b>. Lütfen dikkatli işlem yapınız.
        </div>
        <form asp-action="SalonDuzenle" method="post">
            <input type="hidden" asp-for="SalonId" />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Ad" class="form-label">Salon Adı</label>
                    <input asp-for="Ad" class="form-control bg-dark text-white border-secondary" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Kapasite" class="form-label">Kapasite</label>
                    <input asp-for="Kapasite" type="number" min="1" max="500" class="form-control bg-dark text-white border-secondary" required />
                </div>
            </div>
            <div class="text-end mt-3">
                <button type="submit" class="btn btn-warning"><i class="fas fa-save me-2"></i>Değişiklikleri Kaydet</button>
            </div>
        </form>
    </div>
</div>
