@model List<dbfirstProjem.Models.Seanslar>

@{
    ViewData["Title"] = "Seanslar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-light"><i class="fas fa-clock me-2 text-danger"></i>Seanslar</h3>
    <div class="d-flex align-items-center">
        <form asp-action="Seanslar" method="get" class="d-flex me-3">
            <input type="text" name="searchString" class="form-control bg-dark text-white border-secondary me-2" placeholder="Film veya Salon ara..." value="@Context.Request.Query["searchString"]" style="width: 200px;" />
            <button type="submit" class="btn btn-outline-light"><i class="fas fa-search"></i></button>
        </form>
        <a asp-action="ExportToPdf_Seanslar" class="btn btn-outline-danger me-2">
            <i class="fas fa-file-pdf"></i> PDF İndir
        </a>
        <a asp-action="ExportToExcel_Seanslar" class="btn btn-outline-success me-2">
            <i class="fas fa-file-excel"></i> Excel İndir
        </a>
        <a asp-action="SeansEkle" class="btn btn-danger"><i class="fas fa-plus me-2"></i>Yeni Ekle</a>
    </div>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body p-0">
        <table class="table table-dark table-hover table-striped mb-0">
            <thead>
                <tr>
                    <th>Film Adı</th>
                    <th>Salon Adı</th>
                    <th>Tarih ve Saat</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-secondary py-4">Kayıtlı seans bulunmamaktadır.</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="align-middle">
                            <td>@(item.Film?.Ad ?? "Film Bulunamadı")</td>
                            <td>@(item.Salon?.Ad ?? "Salon Bulunamadı")</td>
                            <td>@item.BaslamaZamani.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">
                                <a asp-action="SeansDuzenle" asp-route-id="@item.SeansId" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="fas fa-edit"></i> Düzenle
                                </a>
                                <a asp-action="SeansSil" asp-route-id="@item.SeansId" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu seansı silmek istediğinize emin misiniz? Bilet alan kullanıcılar etkilenebilir.');">
                                    <i class="fas fa-trash"></i> Sil
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
