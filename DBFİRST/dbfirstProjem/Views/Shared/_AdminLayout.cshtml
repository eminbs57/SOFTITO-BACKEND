<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>Admin Paneli - CINEWAM</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.13.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #121212; color: #fff; overflow-x: hidden; }
        .sidebar { min-height: 100vh; background: #0a0a0a; border-right: 1px solid #333; }
        .sidebar-link { color: #ccc; text-decoration: none; padding: 10px 20px; display: block; border-left: 3px solid transparent; transition: 0.3s; }
        .sidebar-link:hover, .sidebar-link.active { background: #1a1a1a; color: #dc3545; border-left-color: #dc3545; }
        .navbar-admin { background: #dc3545; }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="sidebar flex-shrink-0" style="width: 250px;">
            <div class="p-4 text-center border-bottom border-secondary">
                <h4 class="text-danger fw-bold m-0">CINEWAM</h4>
                <small class="text-secondary">Yönetim Paneli</small>
            </div>
            <div class="py-3">
                <a asp-controller="Admin" asp-action="Index" class="sidebar-link"><i class="fas fa-film me-2"></i> Filmler</a>
                <a asp-controller="Admin" asp-action="FilmEkle" class="sidebar-link"><i class="fas fa-plus me-2"></i> Film Ekle</a>
                <hr class="border-secondary mx-3">
                <a asp-controller="Admin" asp-action="Seanslar" class="sidebar-link"><i class="fas fa-clock me-2"></i> Seanslar</a>
                <a asp-controller="Admin" asp-action="SeansEkle" class="sidebar-link"><i class="fas fa-calendar-plus me-2"></i> Seans Ekle</a>
                <hr class="border-secondary mx-3">
                <a asp-controller="Admin" asp-action="Salonlar" class="sidebar-link"><i class="fas fa-door-open me-2"></i> Salonlar</a>
                <a asp-controller="Admin" asp-action="SalonEkle" class="sidebar-link"><i class="fas fa-plus-square me-2"></i> Salon Ekle</a>
                <hr class="border-secondary mx-3">
                <a asp-controller="Admin" asp-action="Raporlar" class="sidebar-link"><i class="fas fa-chart-pie me-2"></i> Raporlar</a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="flex-grow-1">
            <!-- Navbar -->
            <nav class="navbar navbar-expand-lg navbar-dark navbar-admin shadow-sm">
                <div class="container-fluid">
                    <span class="navbar-brand mb-0 h1">@(ViewData["Title"] ?? "Admin Dashboard")</span>
                    <div class="ms-auto d-flex align-items-center">
                        <span class="text-light me-3"><i class="fas fa-user-shield me-1"></i> @User.Identity?.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-dark btn-sm">Çıkış Yap</button>
                        </form>
                    </div>
                </div>
            </nav>

            <!-- Page Content -->
            <div class="p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
