@using HastaneRandevu.Models
@model IEnumerable<RandevuModel>
@{
    ViewData["Title"] = "Randevular";

    var hastalar = ViewBag.Hastalar as IEnumerable<HastaModel> ?? new List<HastaModel>();
    var doktorlar = ViewBag.Doktorlar as IEnumerable<DoktorModel> ?? new List<DoktorModel>();
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0">Randevu Listesi</h3>
        <div class="d-flex gap-2">
            <a href="/Randevu/DownloadExcel" class="btn btn-sm btn-light border shadow-sm text-secondary" title="Excel İndir">
                <i class="bi bi-file-earmark-excel text-success"></i> Excel
            </a>
            <a href="/Randevu/DownloadPdf" class="btn btn-sm btn-light border shadow-sm text-secondary" title="PDF İndir">
                <i class="bi bi-file-earmark-pdf text-danger"></i> PDF
            </a>
            <a href="/Randevu/EY" class="btn btn-primary shadow-sm ms-2"><i class="bi bi-calendar-plus me-1"></i> Yeni Randevu</a>
        </div>
    </div>

    <div class="card card-modern">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-end align-items-center">
            <form method="get" action="/Randevu/Index" class="d-flex w-100" style="max-width: 400px;">
                <div class="input-group">
                    <span class="input-group-text bg-white text-muted border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchTerm" class="form-control border-start-0 ps-0" placeholder="Durum (Aktif vb.) ile ara..." value="@ViewBag.SearchTerm" />
                    <button type="submit" class="btn btn-outline-primary">Ara</button>
                    @if(!string.IsNullOrEmpty((string)ViewBag.SearchTerm)) {
                        <a href="/Randevu/Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
                    }
                </div>
            </form>
        </div>
        
        <div class="table-responsive">
            <table class="table table-modern table-hover align-middle">
                <thead>
                    <tr>
                        <th>Hasta Adı Soyadı</th>
                        <th>Doktor Adı Soyadı</th>
                        <th>Randevu Tarihi</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@(hastalar.FirstOrDefault(h => h.HastaNo == item.HastaNo)?.AdSoyad)</td>
                            <td>@(doktorlar.FirstOrDefault(d => d.DoktorNo == item.DoktorNo)?.AdSoyad)</td>
                            <td>
                                <i class="bi bi-calendar-event text-muted me-1"></i> 
                                @item.RandevuTarihi.ToString("dd.MM.yyyy") <br/>
                                <small class="text-muted"><i class="bi bi-clock me-1"></i> @item.RandevuTarihi.ToString("HH:mm")</small>
                            </td>
                            <td>
                                @if (item.Durum == "Aktif") {
                                    <span class="badge bg-primary">Aktif</span>
                                }
                                else if (item.Durum == "Tamamlandı") {
                                    <span class="badge bg-success">Tamamlandı</span>
                                }
                                else if (item.Durum == "İptal") {
                                    <span class="badge bg-danger">İptal</span>
                                }
                                else {
                                    <span class="badge bg-secondary border">@item.Durum</span>
                                }
                            </td>
                            <td class="text-end">
                                <a href="/Randevu/EY/@item.RandevuNo" class="btn btn-outline-secondary icon-btn shadow-sm" title="Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Randevu/Delete/@item.RandevuNo" class="btn btn-outline-danger icon-btn shadow-sm ms-1" onclick="return confirm('Randevuyu silmek istediğinize emin misiniz?');" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Kayıt bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>