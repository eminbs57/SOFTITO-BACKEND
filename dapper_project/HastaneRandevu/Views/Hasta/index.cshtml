@model IEnumerable<HastaneRandevu.Models.HastaModel>
@{
    ViewData["Title"] = "Hastalar";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0">Hasta Listesi</h3>
        <a href="/Hasta/EY" class="btn btn-primary shadow-sm"><i class="bi bi-person-plus me-1"></i> Yeni Hasta Ekle</a>
    </div>

    <div class="card card-modern">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-end align-items-center">
            <form method="get" action="/Hasta/Index" class="d-flex w-100" style="max-width: 400px;">
                <div class="input-group">
                    <span class="input-group-text bg-white text-muted border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchTerm" class="form-control border-start-0 ps-0" placeholder="Ad Soyad ile ara..." value="@ViewBag.SearchTerm" />
                    <button type="submit" class="btn btn-outline-primary">Ara</button>
                    @if(!string.IsNullOrEmpty((string)ViewBag.SearchTerm)) {
                        <a href="/Hasta/Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
                    }
                </div>
            </form>
        </div>
        
        <div class="table-responsive">
            <table class="table table-modern table-hover align-middle">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Yaş</th>
                        <th>Telefon</th>
                        <th>Adres</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.AdSoyad</td>
                            <td>@item.Yas</td>
                            <td>@item.Telefon</td>
                            <td><span class="text-muted">@item.Adres</span></td>
                            <td class="text-end">
                                <a href="/Hasta/EY/@item.HastaNo" class="btn btn-outline-secondary icon-btn shadow-sm" title="Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Hasta/Delete/@item.HastaNo" class="btn btn-outline-danger icon-btn shadow-sm ms-1" onclick="return confirm('Bu hastayı silmek istediğinize emin misiniz?');" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Kayıt bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>