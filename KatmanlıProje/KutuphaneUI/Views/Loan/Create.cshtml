@model Kutuphane.Model.Loan

<div class="container">
    <h2>Yeni Ödünç Verme İşlemi</h2>
    <hr />
    <form asp-action="Create" method="post">

        <div class="form-group mb-3">
            <label asp-for="BookId" class="form-label">Kitap Seçin</label>
            <select asp-for="BookId" class="form-control" asp-items="ViewBag.BookId" required>
                <option value="">-- Kitap Seçin --</option>
            </select>

            <span asp-validation-for="BookId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="UserId" class="form-label">Kullanıcı Seçin</label>
            <select asp-for="UserId" class="form-control" asp-items="ViewBag.UserId">
                <option value="">-- Kullanıcı Seçin --</option>
            </select>
            <span asp-validation-for="UserId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="LoanDate" class="form-label">Veriliş Tarihi</label>
            <input asp-for="LoanDate" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            <span asp-validation-for="LoanDate" class="text-danger"></span>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-success">Kaydet</button>
            <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
        </div>
    </form>
</div>