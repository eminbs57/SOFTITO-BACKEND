@model IEnumerable<Kutuphane.Model.User>

<h2>Kullanıcılar</h2>
<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" placeholder="Kullanıcı ara..." class="form-control" />
        <button type="submit" class="btn btn-primary">Ara</button>
    </div>
</form>

<a asp-action="Create" class="btn btn-success mb-3">Yeni Kullanıcı Ekle</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Email</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>