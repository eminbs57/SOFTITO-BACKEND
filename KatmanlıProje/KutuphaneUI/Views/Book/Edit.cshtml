@model Kutuphane.Model.Book
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

</form>
<h2>Kitabı Düzenle</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Title" class="form-label">Kitap Adı</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Author" class="form-label">Yazar</label>
        <input asp-for="Author" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Kategori</label>
        <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Stock" class="form-label">Stok Adedi</label>
        <input asp-for="Stock" class="form-control" type="number" />
    </div>
    <button type="submit" class="btn btn-warning">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>