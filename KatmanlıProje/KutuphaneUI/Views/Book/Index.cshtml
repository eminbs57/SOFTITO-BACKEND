@model IEnumerable<Kutuphane.Model.Book>

<h2>Kitap Listesi</h2>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" placeholder="Kitap adı ara..." class="form-control" />
        <button type="submit" class="btn btn-primary">Ara</button>
    </div>
</form>

<a asp-action="Create" class="btn btn-success mb-3">Yeni Kitap Ekle</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Kitap Adı</th>
            <th>Yazar</th>
            <th>Stok Adedi</th>
            <th>Sayfa Sayısı</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Author</td>
                <td>@item.Stock</td>
                <td>@item.PageCount</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>