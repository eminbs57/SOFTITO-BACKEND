@{
    Layout = "_AdminLayout";
}
<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <h3 class="fw-bold text-dark mb-0">Kullanıcılar</h3>
        <button id="btnAddUser" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="bi bi-plus-lg"></i> Yeni Kullanıcı Ekle</button>
    </div>
    
    <div class="row mb-3">
        <div class="col-md-4">
            <input type="text" id="searchInput" class="form-control" placeholder="Kullanıcı veya rol ara..." />
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="border-0">Kullanıcı Adı</th>
                        <th class="border-0">Rol</th>
                        <th class="border-0 text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="table_data" class="border-top-0">
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="UserModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 id="userHeading">Kullanıcı Ekle</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="UserId" />

                <div class="form-group mb-3">
                    <label>Kullanıcı Adı</label>
                    <input type="text" id="Username" placeholder="Kullanıcı adı giriniz" class="form-control" />
                </div>
                <div class="form-group mb-3" id="passwordGroup">
                    <label>Şifre <small class="text-muted">(Sadece eklerken geçerlidir, güncellenmez)</small></label>
                    <input type="text" id="Password" placeholder="Şifre giriniz" class="form-control" />
                </div>
                <div class="form-group mb-3">
                    <label>Rol</label>
                    <select id="Role" class="form-select">
                        <option value="User">User</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button id="AddUser" class="btn btn-primary" onclick="AddUser()">Kaydet</button>
                <button id="btnUpdate" class="btn btn-primary" onclick="UpdateUser()"
                        style="display:none">Güncelle</button>
                <button class="btn btn-secondary" onclick="HideModalPopUp()">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/User.js" asp-append-version="true"></script>
}