@{
    ViewData["Title"] = "Raporlar";
    Layout = "_AdminLayout";
}

<style>
    .stat-card {
        background: #fff;
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        border-left: 5px solid #2563eb;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.1);
    }
    .stat-icon {
        font-size: 2.5rem;
        color: rgba(37, 99, 235, 0.2);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark">Dashboard</h3>
    <div>
        <button onclick="window.print()" class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm"><i class="bi bi-file-pdf"></i> PDF</button>
        <button onclick="downloadExcel()" class="btn btn-outline-success btn-sm rounded-pill px-3 shadow-sm ms-2"><i class="bi bi-file-excel"></i> Excel</button>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card stat-card h-100 p-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 0.8rem;">Toplam Etkinlik</p>
                    <h2 class="display-5 fw-bold text-dark mb-0">@ViewBag.TotalEvents</h2>
                </div>
                <i class="bi bi-calendar-event stat-icon"></i>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card stat-card h-100 p-3" style="border-left-color: #10b981;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 0.8rem;">Toplam Kategori</p>
                    <h2 class="display-5 fw-bold text-dark mb-0">@ViewBag.TotalCategories</h2>
                </div>
                <i class="bi bi-tags-fill stat-icon" style="color: rgba(16, 185, 129, 0.2);"></i>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card stat-card h-100 p-3" style="border-left-color: #f59e0b;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 0.8rem;">Toplam Kullanıcı</p>
                    <h2 class="display-5 fw-bold text-dark mb-0">@ViewBag.TotalUsers</h2>
                </div>
                <i class="bi bi-people-fill stat-icon" style="color: rgba(245, 158, 11, 0.2);"></i>
            </div>
        </div>
    </div>
</div>

<script>
    function downloadExcel() {
        var csvContent = "data:text/csv;charset=utf-8,\uFEFF";
        csvContent += "Rapor Adi,Sayi\n";
        csvContent += "Toplam Etkinlik,@ViewBag.TotalEvents\n";
        csvContent += "Toplam Kategori,@ViewBag.TotalCategories\n";
        csvContent += "Toplam Kullanici,@ViewBag.TotalUsers\n";

        var encodedUri = encodeURI(csvContent);
        var link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", "Raporlar.csv");
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
</script>
