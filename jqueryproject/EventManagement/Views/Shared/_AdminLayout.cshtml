<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Paneli</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .sidebar {
            height: 100vh;
            background-color: #0f172a;
            color: white;
            position: fixed;
            left: 0;
            top: 0;
            width: 260px;
            padding-top: 20px;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        }
        .sidebar a {
            color: #94a3b8;
            text-decoration: none;
            display: block;
            padding: 12px 20px;
            margin: 4px 12px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .sidebar a:hover, .sidebar a.active {
            color: white;
            background-color: #1e293b;
            transform: translateX(4px);
        }
        .main-content {
            margin-left: 260px;
            padding: 30px;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <h4 class="text-center mb-4">Admin Paneli</h4>
        <a href="/Admin/Index"><i class="bi bi-bar-chart-fill me-2"></i>Raporlar</a>
        <a href="/Event/Index"><i class="bi bi-calendar-event me-2"></i>Etkinlikler</a>
        <a href="/Category/Index"><i class="bi bi-tags-fill me-2"></i>Kategoriler</a>
        <a href="/User/Index"><i class="bi bi-people-fill me-2"></i>Kullanıcılar</a>
        <hr class="text-secondary" />
        <a href="/Account/Logout" class="text-danger"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</a>
    </div>

    <div class="main-content">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
