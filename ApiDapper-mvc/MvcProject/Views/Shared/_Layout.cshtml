<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MvcProject</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MvcProject.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <nav class="sidebar text-white p-3 shadow">
            <a href="/" class="d-flex align-items-center mb-4 mt-2 text-white text-decoration-none border-bottom pb-4 border-secondary border-opacity-25">
                <i class="bi bi-bell-fill text-warning me-3 fs-3" style="color: #D4AF37 !important;"></i>
                <span class="fs-4 fw-bold" style="font-family: 'Playfair Display', serif; letter-spacing: 0.5px;">Otel Yönetimi</span>
            </a>
            
            <ul class="nav nav-pills flex-column mb-auto mt-2 gap-2">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active-link" : "")">
                        <i class="bi bi-grid-1x2-fill me-3"></i>Ana Sayfa
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="RoomTypes" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "RoomTypes" ? "active-link" : "")">
                        <i class="bi bi-tags-fill me-3"></i>Oda Tipleri
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Rooms" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rooms" ? "active-link" : "")">
                        <i class="bi bi-door-closed-fill me-3"></i>Odalar
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Guests" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Guests" ? "active-link" : "")">
                        <i class="bi bi-people-fill me-3"></i>Müşteriler
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Reservations" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservations" ? "active-link" : "")">
                        <i class="bi bi-calendar-check-fill me-3"></i>Rezervasyonlar
                    </a>
                </li>
                <li class="nav-item mt-3">
                    <a asp-controller="Reports" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active-link" : "")">
                        <i class="bi bi-bar-chart-line-fill me-3"></i>Raporlar
                    </a>
                </li>
            </ul>

            @if (User.Identity.IsAuthenticated)
            {
                <hr class="border-secondary border-opacity-25 my-4">
                <div class="mb-3 d-flex flex-column align-items-center">
                    <p class="text-white mb-2 fs-6"><i class="bi bi-person-circle me-2" style="color: #D4AF37;"></i>@User.Identity.Name</p>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="w-100">
                        <button type="submit" class="btn btn-outline-danger w-100 shadow-sm border-0"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</button>
                    </form>
                </div>
            }
        </nav>

        <!-- Main Content -->
        <main class="main-content flex-grow-1 p-4 p-md-5">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
