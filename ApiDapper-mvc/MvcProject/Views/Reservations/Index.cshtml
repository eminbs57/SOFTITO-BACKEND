@model IEnumerable<MvcProject.Models.Reservation>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">Rezervasyonlar</h2>
        <div class="title-accent"></div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ExportToPdf" class="btn btn-danger shadow-sm"><i class="bi bi-file-earmark-pdf me-1"></i>PDF Olarak İndir</a>
        <a asp-action="ExportToExcel" class="btn btn-success shadow-sm"><i class="bi bi-file-earmark-excel me-1"></i>Excel Olarak İndir</a>
        <a asp-action="Create" class="btn btn-premium shadow-sm"><i class="bi bi-plus-lg me-1"></i>Yeni Ekle</a>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group w-50 shadow-sm rounded-3 overflow-hidden">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control form-control-lg border-0" placeholder="İsme, soyisme veya oda numarasına göre ara..." />
        <button class="btn btn-premium px-4" type="submit"><i class="bi bi-search me-1"></i>Ara</button>
        <a asp-action="Index" class="btn btn-outline-secondary px-4 d-flex align-items-center">Temizle</a>
    </div>
</form>

<div class="card premium-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Misafir</th>
                        <th>Oda No</th>
                        <th>Giriş Tarihi</th>
                        <th>Çıkış Tarihi</th>
                        <th>Toplam Fiyat</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
    <tbody>
@foreach (var item in Model) {
            <tr>
                <td class="ps-4 fw-medium text-dark">@item.FirstName @item.LastName</td>
                <td><span class="badge bg-secondary">@item.RoomNumber</span></td>
                <td class="text-muted">@item.CheckInDate.ToShortDateString()</td>
                <td class="text-muted">@item.CheckOutDate.ToShortDateString()</td>
                <td class="text-muted fw-bold">@item.TotalPrice ₺</td>
                <td class="text-end pe-4">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-secondary me-1" title="Düzenle"><i class="bi bi-pencil"></i></a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger" title="Sil" onclick="return confirm('Emin misiniz?');"><i class="bi bi-trash"></i></a>
                </td>
            </tr>
}
        </tbody>
            </table>
        </div>
    </div>
</div>
