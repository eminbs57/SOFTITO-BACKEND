@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-2">
    <div class="row mb-5">
        <div class="col-12">
            <h2 class="page-title">Günlük Özet</h2>
            <div class="title-accent"></div>
            <p class="text-muted mt-2">Resepsiyon yönetim paneline hoş geldiniz.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card stat-card h-100 p-3">
                <div class="card-body d-flex align-items-center p-2">
                    <div class="stat-icon-box bg-primary bg-opacity-10 text-primary shadow-sm me-4">
                        <i class="bi bi-box-arrow-in-right"></i>
                    </div>
                    <div>
                        <div class="stat-label">Giriş Yapacaklar</div>
                        <div class="stat-value">@ViewBag.CheckInsToday</div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card h-100 p-3">
                <div class="card-body d-flex align-items-center p-2">
                    <div class="stat-icon-box bg-danger bg-opacity-10 text-danger shadow-sm me-4">
                        <i class="bi bi-box-arrow-right"></i>
                    </div>
                    <div>
                        <div class="stat-label">Çıkış Yapacaklar</div>
                        <div class="stat-value">@ViewBag.CheckOutsToday</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card stat-card h-100 p-3">
                <div class="card-body d-flex align-items-center p-2">
                    <div class="stat-icon-box bg-warning bg-opacity-10 text-warning shadow-sm me-4">
                        <i class="bi bi-door-closed"></i>
                    </div>
                    <div>
                        <div class="stat-label">Dolu Odalar</div>
                        <div class="stat-value">@ViewBag.OccupiedRooms</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card stat-card h-100 p-3">
                <div class="card-body d-flex align-items-center p-2">
                    <div class="stat-icon-box bg-success bg-opacity-10 text-success shadow-sm me-4">
                        <i class="bi bi-door-open"></i>
                    </div>
                    <div>
                        <div class="stat-label">Müsait Odalar</div>
                        <div class="stat-value">@ViewBag.AvailableRooms</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
