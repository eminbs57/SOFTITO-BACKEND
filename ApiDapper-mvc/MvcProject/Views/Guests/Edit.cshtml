@model MvcProject.Models.Guest

@{
    ViewData["Title"] = "Müşteri Düzenle";
}

<div class="form-card-wrapper mt-4">
    <div class="card premium-card">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <h3 class="fw-bold" style="color: #0A192F;">Müşteri Düzenle</h3>
                <hr class="text-muted opacity-25" />
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="form-group mb-4">
                    <label asp-for="FirstName" class="control-label fw-medium text-secondary mb-1">Adı</label>
                    <input asp-for="FirstName" class="form-control form-input-custom" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                
                <div class="form-group mb-4">
                    <label asp-for="LastName" class="control-label fw-medium text-secondary mb-1">Soyadı</label>
                    <input asp-for="LastName" class="form-control form-input-custom" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                
                <div class="form-group mb-4">
                    <label asp-for="IdentityNumber" class="control-label fw-medium text-secondary mb-1">T.C. Kimlik No / Pasaport</label>
                    <input asp-for="IdentityNumber" class="form-control form-input-custom" />
                    <span asp-validation-for="IdentityNumber" class="text-danger small"></span>
                </div>
                
                <div class="form-group mb-5">
                    <label asp-for="Phone" class="control-label fw-medium text-secondary mb-1">Telefon Numarası</label>
                    <input asp-for="Phone" class="form-control form-input-custom" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                
                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-outline-grey">
                        <i class="bi bi-arrow-left me-1"></i>İptal
                    </a>
                    <button type="submit" class="btn btn-premium">
                        <i class="bi bi-check-lg me-1"></i>Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
